rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // People collection
    match /people/{personId} {
      allow read, write: if true;
    }

    // Families collection
    match /families/{familyId} {
      allow read, write: if true;
    }

    // Structures collection
    match /structures/{structureId} {
      allow read, write: if true;
    }
  }
}

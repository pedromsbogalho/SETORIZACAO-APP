rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // People collection (recursive wildcard for arbitrary IDs/slashes)
    match /people/{document=**} {
      allow read, write: if true;
    }

    // Families collection
    match /families/{document=**} {
      allow read, write: if true;
    }

    // Structures collection
    match /structures/{document=**} {
      allow read, write: if true;
    }
  }
}
